        {
          "title": {
            "_text": "《原神》X全家便利商店聯動活動將自11月27日開跑 將有聯名杯身與杯套"
          },
          "link": {
            "_text": "https://www.moelong.com/moelongnews/archives/30562"
          },
          "comments": {
            "_text": "https://www.moelong.com/moelongnews/archives/30562#respond"
          },
          "dc:creator": {
            "_cdata": "萌朧雪猴"
          },
          "pubDate": {
            "_text": "Sat, 02 Nov 2024 16:05:17 +0000"
          },
          "category": [
            {
              "_cdata": "活動新訊/報導"
            },
            {
              "_cdata": "全家便利商店"
            },
            {
              "_cdata": "原神"
            }
